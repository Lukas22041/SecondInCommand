# Cloudflare Pages cache rules
# Skill icons, API data, fonts, images — cache for 1 day, serve stale for 7 days while revalidating
/api/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/appAssets/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/*.js
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/*.css
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800


